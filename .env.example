# Configuration de l'environnement pour Y-Comm

# Environnement
NODE_ENV=production

# Port du serveur
PORT=3000

# Niveau de logs (debug, info, warn, error)
LOG_LEVEL=info

# Configuration WebSocket
WS_PATH=/ws

# Configuration timeouts (en millisecondes)
WEBSOCKET_TIMEOUT=60000
HEARTBEAT_INTERVAL=30000

# Configuration Nginx (optionnel)
NGINX_PORT=80
NGINX_SSL_PORT=443

# SSL (optionnel)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
